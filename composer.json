{
    "name": "psc-acme/loader-catalog",
    "description": "Package loader-catalog for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\LoaderCatalog\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "brick/math": "^0.12",
        "symfony/dotenv": "^7.0",
        "symfony/filesystem": "^7.0",
        "symfony/serializer": "^7.0",
        "vlucas/phpdotenv": "^5.0",
        "symfony/lock": "^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "mockery/mockery": "^1.6"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}